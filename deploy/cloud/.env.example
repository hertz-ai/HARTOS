# =============================================================================
# LLM-langchain_Chatbot-Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
FLASK_ENV=production
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production
APP_NAME=LLM-Chatbot-Agent

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=your-secure-database-password
POSTGRES_DB=chatbot_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# External database URL (if using managed database like AWS RDS, Azure Database)
# DATABASE_URL=postgresql://user:password@your-db-host.cloud.com:5432/chatbot_db

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# External Redis URL (if using managed Redis like AWS ElastiCache, Azure Cache)
# REDIS_URL=redis://:password@your-redis-host.cloud.com:6379/0

# -----------------------------------------------------------------------------
# LLM API Configuration
# -----------------------------------------------------------------------------
# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# Azure OpenAI (if using Azure)
# AZURE_OPENAI_API_KEY=your-azure-openai-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Local LLM Server (if using local models)
# LLM_BASE_URL=http://localhost:8080/v1
# LLM_MODEL=local-model

# Groq API (if using Groq)
# GROQ_API_KEY=your-groq-api-key

# -----------------------------------------------------------------------------
# Google Cloud Configuration
# -----------------------------------------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/gcp-service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_CSE_ID=your-custom-search-engine-id

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# Crossbar Router (for pub/sub)
CROSSBAR_URL=http://crossbar:8080/ws
CROSSBAR_REALM=realm1

# Student API Endpoint
STUDENT_API_URL=http://student-api:8080

# Action API Endpoint
ACTION_API_URL=http://action-api:8080

# Autogen Response Endpoint
AUTOGEN_RESPONSE_URL=http://autogen-api:8080/autogen_response

# -----------------------------------------------------------------------------
# Gunicorn Worker Configuration
# -----------------------------------------------------------------------------
WORKERS=4
THREADS=4
TIMEOUT=120
GUNICORN_KEEP_ALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=50

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
SECURE_COOKIES=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# JWT Configuration (if using JWT auth)
# JWT_SECRET_KEY=your-jwt-secret-key
# JWT_ACCESS_TOKEN_EXPIRES=3600
# JWT_REFRESH_TOKEN_EXPIRES=604800

# -----------------------------------------------------------------------------
# Social Integration Settings
# -----------------------------------------------------------------------------
# Telegram Bot
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Discord Bot
# DISCORD_BOT_TOKEN=your-discord-bot-token

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
# Sentry (Error Tracking)
# SENTRY_DSN=https://your-sentry-dsn

# Prometheus Metrics
# PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_SOCIAL_FEATURES=true
ENABLE_AGENT_EVOLUTION=true
ENABLE_GAMIFICATION=true
ENABLE_FEDERATION=false

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_BURST=20

# -----------------------------------------------------------------------------
# Memory & Performance
# -----------------------------------------------------------------------------
# ChromaDB persistence
CHROMA_PERSIST_DIRECTORY=/app/data/chroma

# Vector store settings
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIMENSION=1536
