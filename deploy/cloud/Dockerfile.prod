# Production Dockerfile for HARTOS
# Optimized for cloud deployment with gunicorn

# Multi-arch build args (docker buildx)
ARG TARGETPLATFORM
ARG BUILDPLATFORM

# Build stage for dependencies
FROM --platform=$BUILDPLATFORM python:3.11-slim as builder

WORKDIR /build

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    g++ \
    libffi-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for layer caching
COPY requirements.txt .
COPY agent-ledger-opensource/ ./agent-ledger-opensource/

# Create virtual environment and install dependencies
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN pip install --upgrade pip wheel setuptools && \
    pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir ./agent-ledger-opensource && \
    pip install --no-cache-dir \
        gunicorn[gevent]==21.2.0 \
        gevent==23.9.1 \
        autogen-agentchat==0.2.37 \
        apscheduler \
        autobahn==23.1.2 \
        autobahn[serialization] \
        autobahn[twisted] \
        json-repair \
        mysql-connector-python \
        redis[hiredis]

# Production stage
FROM python:3.11-slim as production

# Labels for container metadata
LABEL maintainer="HARTOS Team"
LABEL version="1.0.0"
LABEL description="Production build of HARTOS"
LABEL org.opencontainers.image.platforms="linux/amd64,linux/arm64"

# Create non-root user for security
RUN groupadd -r appgroup && useradd -r -g appgroup appuser

WORKDIR /app

# Install runtime dependencies only
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 \
    libglib2.0-0 \
    libmariadb3 \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Copy virtual environment from builder
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy application code
COPY langchain_gpt_api.py .
COPY config.json .
COPY helper.py .
COPY threadlocal.py .
COPY reuse_recipe.py .
COPY create_recipe.py .
COPY cultural_wisdom.py .
COPY lifecycle_hooks.py .
COPY helper_ledger.py .
COPY exception_collector.py .
COPY gather_agentdetails.py .
COPY recipe_experience.py .

# Copy core modules
COPY core/ ./core/

# Copy integrations (social and other essential modules)
COPY integrations/ ./integrations/

# Copy agent-ledger package
COPY agent-ledger-opensource/ ./agent-ledger-opensource/

# Copy prompts
COPY prompts/ ./prompts/

# Copy security module
COPY security/ ./security/

# Copy build scripts (needed for hevolveai compilation)
COPY scripts/ ./scripts/

# Create placeholder release manifest (CI/CD pipeline overwrites with signed version)
RUN echo '{"version": "dev", "signed": false}' > release_manifest.json

# Create necessary directories
RUN mkdir -p /app/logs /app/media /app/output_images /app/agent_data

# ── HevolveAI source protection ──
# Compile .py → .pyc, strip source, clean metadata that leaks git URLs
RUN python scripts/compile_hevolveai.py --strip-source \
    --manifest-out security/hevolveai_manifest.json 2>/dev/null || true && \
    # Remove .dist-info/direct_url.json (leaks git+ssh:// origin)
    find /opt/venv/lib -path '*/hevolveai*dist-info/direct_url.json' -delete 2>/dev/null || true && \
    # Remove RECORD file (full file listing)
    find /opt/venv/lib -path '*/hevolveai*dist-info/RECORD' -delete 2>/dev/null || true && \
    # Remove build scripts from final image
    rm -rf /app/scripts

# DEPLOYMENT: Run with read-only filesystem to prevent runtime code modification:
#   docker run --read-only --tmpfs /tmp --tmpfs /app/logs --tmpfs /app/agent_data ...

# Create log file
RUN touch /app/langchain.log

# Set proper permissions
RUN chown -R appuser:appgroup /app

# Switch to non-root user
USER appuser

# Environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/app \
    FLASK_ENV=production \
    DOCKER_CONTAINER=true \
    WORKERS=4 \
    THREADS=2 \
    TIMEOUT=120 \
    HEVOLVE_ENFORCEMENT_MODE=hard

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Run with gunicorn
CMD ["sh", "-c", "gunicorn --bind 0.0.0.0:8000 --workers ${WORKERS} --threads ${THREADS} --timeout ${TIMEOUT} --worker-class gevent --access-logfile - --error-logfile - --capture-output langchain_gpt_api:app"]
