[Unit]
Description=HyveOS OEM First User Setup
After=network-online.target
Wants=network-online.target
ConditionPathExists=!/var/lib/hyve/.first-boot-done

[Service]
Type=oneshot
ExecStart=/bin/bash /opt/hyve/deploy/distro/oem/hyve-oem-config.sh --user-setup
RemainAfterExit=no
TimeoutStartSec=300
StandardOutput=journal+console
StandardError=journal+console

[Install]
WantedBy=multi-user.target
