[Unit]
Description=HyveOS First Boot Setup
After=network-online.target
Wants=network-online.target
ConditionPathExists=!/var/lib/hyve/.first-boot-done

[Service]
Type=oneshot
ExecStart=/bin/bash /opt/hyve/deploy/distro/first-boot/hyve-first-boot.sh
RemainAfterExit=no
TimeoutStartSec=300
StandardOutput=journal+console
StandardError=journal+console

[Install]
WantedBy=multi-user.target
