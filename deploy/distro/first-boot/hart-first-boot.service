[Unit]
Description=HART OS First Boot Setup
After=network-online.target
Wants=network-online.target
ConditionPathExists=!/var/lib/hart/.first-boot-done

[Service]
Type=oneshot
ExecStart=/bin/bash /opt/hart/deploy/distro/first-boot/hart-first-boot.sh
RemainAfterExit=no
TimeoutStartSec=300
StandardOutput=journal+console
StandardError=journal+console

[Install]
WantedBy=multi-user.target
