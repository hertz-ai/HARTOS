#cloud-config
autoinstall:
  version: 1

  identity:
    hostname: hyve-node
    username: hyve
    # Password: "hyve" (change on first login)
    password: "$6$rounds=4096$HyveOS$RJo8GhZFq0Hw/oLvzM5Z3t5Rn.xLjfZdNqBw8yK0sG7E6k4FtTkNQu2w9Y1vDgA6FxrQ3HjV1w0JzJcV8MJq."

  locale: en_US.UTF-8

  keyboard:
    layout: us

  storage:
    layout:
      name: lvm

  network:
    version: 2
    ethernets:
      id0:
        match:
          name: "en*"
        dhcp4: true

  ssh:
    install-server: true
    allow-pw: true

  packages:
    - python3.10
    - python3.10-venv
    - python3.10-dev
    - python3-pip
    - ufw
    - git
    - curl
    - rsync
    - xxd
    - htop
    - nvtop

  late-commands:
    # Copy HyveOS from ISO media to target
    - curtin in-target -- mkdir -p /opt/hyve
    - cp -r /cdrom/hyve-os/ /target/opt/hyve/ || true
    # Install HyveOS
    - curtin in-target -- bash /opt/hyve/deploy/linux/install.sh --from-iso
    # Enable first-boot wizard
    - curtin in-target -- cp /opt/hyve/deploy/distro/first-boot/hyve-first-boot.service /etc/systemd/system/
    - curtin in-target -- systemctl enable hyve-first-boot.service
    # Install branding
    - cp /opt/hyve/deploy/distro/branding/hyve-os-release /target/etc/os-release
    - cp /opt/hyve/deploy/distro/branding/hyve-issue /target/etc/issue
    - cp /opt/hyve/deploy/distro/branding/hyve-motd.sh /target/etc/update-motd.d/99-hyve
    - chmod +x /target/etc/update-motd.d/99-hyve
    # Kernel tuning
    - cp /opt/hyve/deploy/distro/kernel/99-hyve-sysctl.conf /target/etc/sysctl.d/
    - cp /opt/hyve/deploy/distro/kernel/hyve-limits.conf /target/etc/security/limits.d/

  user-data:
    runcmd:
      - systemctl enable hyve.target
