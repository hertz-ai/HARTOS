#include <tunables/global>

/opt/hyve/venv/bin/python {
  #include <abstractions/base>
  #include <abstractions/python>
  #include <abstractions/nameservice>
  #include <abstractions/ssl_certs>

  # Application code (read-only)
  /opt/hyve/** r,
  /opt/hyve/venv/bin/python ix,

  # Writable data directories
  /var/lib/hyve/** rw,
  /var/lib/hyve/hevolve_database.db rwk,
  /var/lib/hyve/agent_data/** rw,
  /var/log/hyve/** w,

  # Config (read-only)
  /etc/hyve/** r,

  # Network
  network inet stream,
  network inet dgram,
  network inet6 stream,

  # Deny sensitive
  deny /etc/shadow r,
  deny /root/** rw,
  deny /home/*/.ssh/** rw,

  # Temp
  /tmp/** rw,
  /proc/*/status r,
  /proc/meminfo r,
  /sys/class/drm/** r,
}
