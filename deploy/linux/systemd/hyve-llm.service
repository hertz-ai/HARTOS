[Unit]
Description=HyveOS Local LLM (llama.cpp)
Documentation=https://github.com/hevolve-ai/hyve
After=network.target
ConditionPathExists=/opt/hyve/models/default.gguf

[Service]
Type=simple
User=hyve
Group=hyve
ExecStart=/opt/hyve/bin/llama-server --model /opt/hyve/models/default.gguf --port ${HYVE_LLM_PORT:-8080} --ctx-size 4096 --threads ${HYVE_LLM_THREADS:-4}
EnvironmentFile=/etc/hyve/hyve.env
Restart=on-failure
RestartSec=10
TimeoutStartSec=60

# LLM needs GPU access
SupplementaryGroups=video render
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/opt/hyve/models
PrivateTmp=yes

StandardOutput=journal
StandardError=journal
SyslogIdentifier=hyve-llm

[Install]
WantedBy=hyve.target
