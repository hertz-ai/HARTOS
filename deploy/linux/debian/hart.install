# HART OS file mapping for dpkg
# Source paths are relative to the package build root

# Application code
opt/hart/

# Configuration template
etc/hart/hart.env.template

# systemd units
etc/systemd/system/hart-backend.service
etc/systemd/system/hart-discovery.service
etc/systemd/system/hart-vision.service
etc/systemd/system/hart-llm.service
etc/systemd/system/hart-agent-daemon.service
etc/systemd/system/hart.target

# CLI tool
usr/local/bin/hart

# Firewall profiles
etc/ufw/applications.d/hart
