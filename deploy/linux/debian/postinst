#!/bin/bash
# HyveOS post-installation script
# Runs after .deb package files are installed

set -e

INSTALL_DIR="/opt/hyve"

echo "[HyveOS] Running post-install setup..."

# Run the main installer in post-install mode
if [[ -f "$INSTALL_DIR/deploy/linux/install.sh" ]]; then
    bash "$INSTALL_DIR/deploy/linux/install.sh" --from-iso
fi

echo "[HyveOS] Post-install complete."
echo "[HyveOS] Edit /etc/hyve/hyve.env to configure API keys."
echo "[HyveOS] Run 'hyve status' to check service status."
