# HART OS Environment Configuration
# Copy to /etc/hart/hart.env and edit values

# ============================================================
# Core
# ============================================================
HEVOLVE_DB_PATH=/var/lib/hart/hevolve_database.db
PYTHONDONTWRITEBYTECODE=1
HART_VERSION=1.0.0
HART_NODE_NAME=

# ============================================================
# Deployment Mode
# ============================================================
# Set to true when running as HART OS (the operating system).
# Auto-detected on NixOS via /etc/os-release ID=hart-os.
# When true, services use privileged ports (<1024), freeing
# user-space ports (1024-65535) for user applications.
# HART_OS_MODE=false

# ============================================================
# Ports
# ============================================================
# App-mode (default):    OS-mode (HART_OS_MODE=true):
#   backend    = 6777      backend    = 677
#   discovery  = 6780      discovery  = 678
#   vision     = 9891      vision     = 989
#   websocket  = 5460      websocket  = 546
#   llm        = 8080      llm        = 808
#   diarization= 8004      diarization= 800
#   dlna_stream= 8554      dlna_stream= 855
#   mesh_wg    = 6795      mesh_wg    = 679
#   mesh_relay = 6796      mesh_relay = 680
#
# Override any port individually (takes precedence over mode):
HARTOS_BACKEND_PORT=6777
HART_DISCOVERY_PORT=6780
HART_VISION_PORT=9891
HART_WS_PORT=5460
HART_LLM_PORT=8080
HEVOLVE_DIARIZATION_PORT=8004
HART_DLNA_PORT=8554
HART_MESH_WG_PORT=6795
HART_MESH_RELAY_PORT=6796

# ============================================================
# API Keys (optional — local-only mode works without these)
# ============================================================
OPENAI_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
NEWS_API_KEY=
SERPAPI_API_KEY=
LANGCHAIN_API_KEY=

# ============================================================
# Azure (optional)
# ============================================================
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01

# ============================================================
# Security
# ============================================================
# Node keypair auto-generated at install; do NOT set manually
# HEVOLVE_NODE_PRIVATE_KEY_PATH=/var/lib/hart/node_private.key
# HEVOLVE_NODE_PUBLIC_KEY_PATH=/var/lib/hart/node_public.key

# Domain-based regional provisional authorization
# Nodes on *.hevolve.ai / *.hertzai.com get provisional regional status
# via socket.getfqdn(). Central verifies via challenge-response and
# auto-issues a short-lived certificate. Domain list is hardcoded in
# security/key_delegation.py (not configurable — prevents spoofing).

# ============================================================
# LLM Configuration
# ============================================================
HART_LLM_THREADS=4
HART_LLM_CTX_SIZE=4096
# Path to GGUF model for local inference
HART_LLM_MODEL_PATH=/opt/hart/models/default.gguf

# ============================================================
# Network
# ============================================================
# Peer to auto-join on startup (optional)
HART_JOIN_PEER=
# Gossip interval in seconds
HART_GOSSIP_INTERVAL=60
