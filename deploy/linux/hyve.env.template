# HyveOS Environment Configuration
# Copy to /etc/hyve/hyve.env and edit values

# ============================================================
# Core
# ============================================================
HEVOLVE_DB_PATH=/var/lib/hyve/hevolve_database.db
PYTHONDONTWRITEBYTECODE=1
HYVE_VERSION=1.0.0
HYVE_NODE_NAME=

# ============================================================
# Ports
# ============================================================
HYVE_BACKEND_PORT=6777
HYVE_DISCOVERY_PORT=6780
HYVE_VISION_PORT=9891
HYVE_WS_PORT=5460
HYVE_LLM_PORT=8080

# ============================================================
# API Keys (optional — local-only mode works without these)
# ============================================================
OPENAI_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
NEWS_API_KEY=
SERPAPI_API_KEY=
LANGCHAIN_API_KEY=

# ============================================================
# Azure (optional)
# ============================================================
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01

# ============================================================
# Security
# ============================================================
# Node keypair auto-generated at install; do NOT set manually
# HEVOLVE_NODE_PRIVATE_KEY_PATH=/var/lib/hyve/node_private.key
# HEVOLVE_NODE_PUBLIC_KEY_PATH=/var/lib/hyve/node_public.key

# ============================================================
# LLM Configuration
# ============================================================
HYVE_LLM_THREADS=4
HYVE_LLM_CTX_SIZE=4096
# Path to GGUF model for local inference
HYVE_LLM_MODEL_PATH=/opt/hyve/models/default.gguf

# ============================================================
# Network
# ============================================================
# Peer to auto-join on startup (optional)
HYVE_JOIN_PEER=
# Gossip interval in seconds
HYVE_GOSSIP_INTERVAL=60
