# HevolveBot Environment Variables
# Copy to .env and fill in values

# REQUIRED: Master key for secrets vault encryption
HEVOLVE_MASTER_KEY=your-strong-master-key-here

# API key for authenticating requests to core endpoints
HEVOLVE_API_KEY=

# LLM Provider Keys (alternatively stored in encrypted vault)
OPENAI_API_KEY=
GROQ_API_KEY=
LANGCHAIN_API_KEY=

# Search & External APIs
GOOGLE_CSE_ID=
GOOGLE_API_KEY=
NEWS_API_KEY=
SERPAPI_API_KEY=

# Memory Service
ZEP_API_KEY=

# Social Platform JWT Secret (REQUIRED - no default allowed)
SOCIAL_SECRET_KEY=

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://user:pass@localhost/hevolve

# Database encryption key (for SQLite/SQLCipher)
SOCIAL_DB_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_RATE_LIMIT_URL=redis://localhost:6379/1

# TLS Configuration
TLS_CERT_PATH=
TLS_KEY_PATH=
HEVOLVE_CA_BUNDLE=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Environment: development | production
HEVOLVE_ENV=development

# MCP Server Allowlist (comma-separated hostnames)
MCP_ALLOWED_SERVERS=localhost

# Deployment Integrity (dev defaults - override for production)
HEVOLVE_DEV_MODE=true
HEVOLVE_ENFORCEMENT_MODE=off
